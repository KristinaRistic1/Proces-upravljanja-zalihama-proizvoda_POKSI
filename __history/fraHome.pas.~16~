procedure TFrame5.ListBox1Click(Sender: TObject);
begin
  if ListBox1.ItemIndex < 0 then Exit;
  ActivePetIndex := ListBox1.ItemIndex;
  RefreshMainCard;
  ListBox1.Visible := False;
end;

