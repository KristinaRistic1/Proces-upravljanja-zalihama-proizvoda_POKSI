unit fraMagacin;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes, System.Variants,
  FMX.Types, FMX.Graphics, FMX.Controls, FMX.Forms, FMX.Dialogs, FMX.StdCtrls,
  FMX.Objects, FMX.Controls.Presentation, FMX.Layouts, FMX.ListBox, FMX.Edit,
  FMX.ScrollBox,
  FireDAC.Comp.Client, uUserStore, uNavFrames, fraTok;

type
  TfraMagacin = class(TFrame)
    Layout1: TLayout;
    Layout2: TLayout;
    rectHeader: TRectangle;
    lblBack: TLabel;
    lblTitle: TLabel;
    Layout3: TLayout;
    edtPretraga: TEdit;
    layFilteri: TLayout;
    rectSve: TRectangle;
    lblSve: TLabel;
    rectHrana: TRectangle;
    lblHrana: TLabel;
    rectHigijena: TRectangle;
    lblHigijena: TLabel;
    rectLekovi: TRectangle;
    lblLekovi: TLabel;
    lstArtikli: TListBox;
    rectDugmePlus: TRectangle;
    lblPlus: TLabel;
    Layout4: TLayout;
    rectNav: TRectangle;
    layNav: TLayout;
    GridLayout1: TGridLayout;
    Image1: TImage;
    Image2: TImage;
    Image3: TImage;
    Image4: TImage;
    procedure edtPretragaChange(Sender: TObject);
    procedure rectSveClick(Sender: TObject);
    procedure rectHranaClick(Sender: TObject);
    procedure rectHigijenaClick(Sender: TObject);
    procedure rectLekoviClick(Sender: TObject);
    procedure rectDugmePlusClick(Sender: TObject);
    procedure lblBackClick(Sender: TObject);
    procedure rectTokClick(Sender: TObject);
    procedure Loaded; override;
  private
    FFilter: string;
    procedure UcitajArtikle;
    procedure PostaviAktivniFilter(Active: TRectangle);
    procedure DodajKarticu(const Naziv, Kategorija, JedinicaMere: string;
                           Kolicina, Minimum: Double;
                           const DatumNabavke, ImeDobavljaca: string;
                           const RokTrajanja: TDateTime;
                           ImaRok: Boolean);
  public
  end;

implementation
{$R *.fmx}

procedure TfraMagacin.Loaded;
begin
  inherited;
  FFilter := '';
  PostaviAktivniFilter(rectSve);
  UcitajArtikle;
end;

procedure TfraMagacin.lblBackClick(Sender: TObject);
begin
  TNavFrames.Back;
end;

procedure TfraMagacin.PostaviAktivniFilter(Active: TRectangle);
var
  Svi: array[0..3] of TRectangle;
  Labele: array[0..3] of TLabel;
  i: Integer;
begin
  Svi[0] := rectSve;      Labele[0] := lblSve;
  Svi[1] := rectHrana;    Labele[1] := lblHrana;
  Svi[2] := rectHigijena; Labele[2] := lblHigijena;
  Svi[3] := rectLekovi;   Labele[3] := lblLekovi;

  for i := 0 to 3 do
  begin
    if Svi[i] = Active then
    begin
      Svi[i].Fill.Color := TAlphaColorRec.Yellow;
      Labele[i].TextSettings.Font.Style := [TFontStyle.fsBold];
      Labele[i].TextSettings.FontColor := $FF1F2937;
    end
    else
    begin
      Svi[i].Fill.Color := $FFE5E7EB;
      Labele[i].TextSettings.Font.Style := [];
      Labele[i].TextSettings.FontColor := $FF6B7280;
    end;
  end;
end;

procedure TfraMagacin.DodajKarticu(const Naziv, Kategorija, JedinicaMere: string;
                                    Kolicina, Minimum: Double;
                                    const DatumNabavke, ImeDobavljaca: string;
                                    const RokTrajanja: TDateTime;
                                    ImaRok: Boolean);
var
  Item: TListBoxItem;
  rectKartica, rectTraka: TRectangle;
  layKartica: TLayout;
  lblNaziv, lblStanje, lblDatum, lblDobavljac, lblUpozorenje, lblRok: TLabel;
  Boja: TAlphaColor;
  DanaDo: Integer;
  RokTekst: string;
  RokBoja: TAlphaColor;
  VisKartice: Integer;
begin
  if (Minimum > 0) and (Kolicina < Minimum) then
    Boja := $FFEF4444
  else if (Minimum > 0) and (Kolicina < Minimum * 1.5) then
    Boja := $FFF59E0B
  else
    Boja := $FF22C55E;

  VisKartice := 200;
  RokTekst := '';
  RokBoja := $FF9CA3AF;

  if ImaRok then
  begin
    DanaDo := Trunc(RokTrajanja - Now);
    if DanaDo < 0 then
    begin
      RokTekst := 'ISTEKAO rok trajanja (' + FormatDateTime('dd.mm.yyyy', RokTrajanja) + ')!';
      RokBoja := $FFEF4444;
      VisKartice := 240;
    end
    else if DanaDo <= 30 then
    begin
      RokTekst := 'Rok istice za ' + IntToStr(DanaDo) + ' dana (' + FormatDateTime('dd.mm.yyyy', RokTrajanja) + ')';
      RokBoja := $FFF59E0B;
      VisKartice := 240;
    end
    else
    begin
      RokTekst := 'Rok trajanja: ' + FormatDateTime('dd.mm.yyyy', RokTrajanja);
      RokBoja := $FF9CA3AF;
    end;
  end;

  if (Minimum > 0) and (Kolicina < Minimum) then
    VisKartice := VisKartice + 20;

  Item := TListBoxItem.Create(lstArtikli);
  Item.Height := VisKartice;
  Item.StyleLookup := '';

  rectKartica := TRectangle.Create(Item);
  rectKartica.Parent := Item;
  rectKartica.Align := TAlignLayout.Client;
  rectKartica.Margins.Left   := 4;
  rectKartica.Margins.Right  := 4;
  rectKartica.Margins.Top    := 4;
  rectKartica.Margins.Bottom := 4;
  rectKartica.Fill.Color := TAlphaColors.White;
  rectKartica.Stroke.Color := $FFE5E7EB;
  rectKartica.Stroke.Thickness := 1;
  rectKartica.XRadius := 12;
  rectKartica.YRadius := 12;

  rectTraka := TRectangle.Create(rectKartica);
  rectTraka.Parent := rectKartica;
  rectTraka.Align := TAlignLayout.Left;
  rectTraka.Width := 6;
  rectTraka.Fill.Color := Boja;
  rectTraka.Stroke.Kind := TBrushKind.None;
  rectTraka.XRadius := 12;
  rectTraka.YRadius := 12;

  layKartica := TLayout.Create(rectKartica);
  layKartica.Parent := rectKartica;
  layKartica.Align := TAlignLayout.Client;
  layKartica.Padding.Left   := 12;
  layKartica.Padding.Right  := 12;
  layKartica.Padding.Top    := 8;
  layKartica.Padding.Bottom := 8;

  // VAZNO: Align=Top dodaje odozdo prema gore
  // Zato dodajemo obrnutim redoslijedom — ono sto zelimo na dnu ide prvo!

  // Dobavljac (ide na dno — dodaj prvi)
  lblDobavljac := TLabel.Create(layKartica);
  lblDobavljac.Parent := layKartica;
  lblDobavljac.Align := TAlignLayout.Top;
  lblDobavljac.Height := 18;
  if ImeDobavljaca <> '' then
    lblDobavljac.Text := 'Dobavljac: ' + ImeDobavljaca
  else
    lblDobavljac.Text := 'Dobavljac: nema podataka';
  lblDobavljac.StyledSettings := [];
  lblDobavljac.TextSettings.Font.Size := 10;
  lblDobavljac.TextSettings.FontColor := $FF9CA3AF;

  // Datum nabavke
  lblDatum := TLabel.Create(layKartica);
  lblDatum.Parent := layKartica;
  lblDatum.Align := TAlignLayout.Top;
  lblDatum.Height := 18;
  lblDatum.Margins.Top := 2;
  if DatumNabavke <> '' then
    lblDatum.Text := 'Poslednja nabavka: ' + DatumNabavke
  else
    lblDatum.Text := 'Poslednja nabavka: nema podataka';
  lblDatum.StyledSettings := [];
  lblDatum.TextSettings.Font.Size := 10;
  lblDatum.TextSettings.FontColor := $FF9CA3AF;

  // Rok trajanja
  if RokTekst <> '' then
  begin
    lblRok := TLabel.Create(layKartica);
    lblRok.Parent := layKartica;
    lblRok.Align := TAlignLayout.Top;
    lblRok.Height := 18;
    lblRok.Margins.Top := 2;
    lblRok.Text := RokTekst;
    lblRok.StyledSettings := [];
    lblRok.TextSettings.Font.Size := 10;
    lblRok.TextSettings.Font.Style := [TFontStyle.fsBold];
    lblRok.TextSettings.FontColor := RokBoja;
  end;

  // Upozorenje ispod minimuma
  if (Minimum > 0) and (Kolicina < Minimum) then
  begin
    lblUpozorenje := TLabel.Create(layKartica);
    lblUpozorenje.Parent := layKartica;
    lblUpozorenje.Align := TAlignLayout.Top;
    lblUpozorenje.Height := 18;
    lblUpozorenje.Margins.Top := 2;
    lblUpozorenje.Text := 'Zalihe ispod minimuma - potrebna nabavka!';
    lblUpozorenje.StyledSettings := [];
    lblUpozorenje.TextSettings.Font.Size := 10;
    lblUpozorenje.TextSettings.FontColor := $FFEF4444;
  end;

  // Stanje
  lblStanje := TLabel.Create(layKartica);
  lblStanje.Parent := layKartica;
  lblStanje.Align := TAlignLayout.Top;
  lblStanje.Height := 18;
  lblStanje.Margins.Top := 2;
  lblStanje.Text := 'TRENUTNO STANJE: ' + FormatFloat('0.#', Kolicina) +
                    ' ' + JedinicaMere + '  |  Min: ' +
                    FormatFloat('0.#', Minimum) + ' ' + JedinicaMere;
  lblStanje.StyledSettings := [];
  lblStanje.TextSettings.Font.Size := 11;
  lblStanje.TextSettings.Font.Style := [TFontStyle.fsBold];
  lblStanje.TextSettings.FontColor := Boja;

  // NAZIV — dodaj zadnjeg da bude na vrhu!
  lblNaziv := TLabel.Create(layKartica);
  lblNaziv.Parent := layKartica;
  lblNaziv.Align := TAlignLayout.Top;
  lblNaziv.Height := 22;
  lblNaziv.Text := UpperCase(Naziv);
  lblNaziv.StyledSettings := [];
  lblNaziv.TextSettings.Font.Size := 13;
  lblNaziv.TextSettings.Font.Style := [TFontStyle.fsBold];
  lblNaziv.TextSettings.FontColor := $FF111827;

  lstArtikli.AddObject(Item);
end;

procedure TfraMagacin.UcitajArtikle;
var
  Q: TFDQuery;
  SQL: string;
  Naziv, Kategorija, JedinicaMere: string;
  Kolicina, Minimum: Double;
  DatumNabavke, ImeDobavljaca: string;
  RokTrajanja: TDateTime;
  ImaRok: Boolean;
begin
  lstArtikli.BeginUpdate;
  try
    lstArtikli.Clear;
    Q := TFDQuery.Create(nil);
    try
      Q.Connection := DB;

      SQL :=
        'SELECT R.SifraResursa, R.Naziv, R.Kategorija, R.TrenutnaKolicina, ' +
        '       R.MinimaKolicina, R.JedinicaMere, R.RokTrajanja, ' +
        '       MAX(N.Datum) as DatumNabavke, ' +
        '       D.Naziv as ImeDobavljaca ' +
        'FROM RESURS R ' +
        'LEFT JOIN STAVKA_NARUDZBINE SN ON SN.SifraResursa = R.SifraResursa ' +
        'LEFT JOIN NARUDZBINA N ON N.BrojNarudzbine = SN.BrojNarudzbine ' +
        'LEFT JOIN DOBAVLJAC D ON D.SifraDobavljaca = N.SifraDobavljaca ';

      if FFilter <> '' then
        SQL := SQL + 'WHERE lower(R.Kategorija) = lower(''' + FFilter + ''') ';

      if Trim(edtPretraga.Text) <> '' then
      begin
        if FFilter <> '' then
          SQL := SQL + 'AND lower(R.Naziv) LIKE lower(''%' + Trim(edtPretraga.Text) + '%'') '
        else
          SQL := SQL + 'WHERE lower(R.Naziv) LIKE lower(''%' + Trim(edtPretraga.Text) + '%'') ';
      end;

      SQL := SQL + 'GROUP BY R.SifraResursa ORDER BY R.Naziv';
      Q.SQL.Text := SQL;
      Q.Open;

      while not Q.Eof do
      begin
        Naziv         := Q.FieldByName('Naziv').AsString;
        Kategorija    := Q.FieldByName('Kategorija').AsString;
        JedinicaMere  := Q.FieldByName('JedinicaMere').AsString;
        Kolicina      := Q.FieldByName('TrenutnaKolicina').AsFloat;
        Minimum       := Q.FieldByName('MinimaKolicina').AsFloat;
        DatumNabavke  := Q.FieldByName('DatumNabavke').AsString;
        ImeDobavljaca := Q.FieldByName('ImeDobavljaca').AsString;

        ImaRok := not Q.FieldByName('RokTrajanja').IsNull and
                  (Q.FieldByName('RokTrajanja').AsString <> '');
        if ImaRok then
        begin
          try
            RokTrajanja := Q.FieldByName('RokTrajanja').AsDateTime;
          except
            ImaRok := False;
            RokTrajanja := 0;
          end;
        end
        else
          RokTrajanja := 0;

        DodajKarticu(Naziv, Kategorija, JedinicaMere,
                     Kolicina, Minimum, DatumNabavke, ImeDobavljaca,
                     RokTrajanja, ImaRok);
        Q.Next;
      end;

      if lstArtikli.Count = 0 then
      begin
        var Item := TListBoxItem.Create(lstArtikli);
        Item.Height := 60;
        Item.Text := 'Nema artikala za prikaz.';
        lstArtikli.AddObject(Item);
      end;

    finally
      Q.Free;
    end;
  finally
    lstArtikli.EndUpdate;
  end;
end;

procedure TfraMagacin.rectSveClick(Sender: TObject);
begin
  FFilter := '';
  PostaviAktivniFilter(rectSve);
  UcitajArtikle;
end;

procedure TfraMagacin.rectHranaClick(Sender: TObject);
begin
  FFilter := 'hrana';
  PostaviAktivniFilter(rectHrana);
  UcitajArtikle;
end;

procedure TfraMagacin.rectHigijenaClick(Sender: TObject);
begin
  FFilter := 'kozmetika';
  PostaviAktivniFilter(rectHigijena);
  UcitajArtikle;
end;

procedure TfraMagacin.rectLekoviClick(Sender: TObject);
begin
  FFilter := 'lek';
  PostaviAktivniFilter(rectLekovi);
  UcitajArtikle;
end;

procedure TfraMagacin.edtPretragaChange(Sender: TObject);
begin
  UcitajArtikle;
end;

procedure TfraMagacin.rectDugmePlusClick(Sender: TObject);
begin
  ShowMessage('Koristite meni za nabavku!');
end;

procedure TfraMagacin.rectTokClick(Sender: TObject);
begin
  TNavFrames.Go(TfraTok.Create(nil));
end;

end.
