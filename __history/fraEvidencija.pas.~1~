unit fraEvidencija;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes, System.Variants,
  FMX.Types, FMX.Graphics, FMX.Controls, FMX.Forms, FMX.Dialogs, FMX.StdCtrls,
  FMX.Edit, FMX.Objects, FMX.Controls.Presentation, FMX.Layouts, FMX.ListBox,
  FireDAC.Comp.Client, uUserStore, uNavFrames;

type
  TfraEvidencija = class(TFrame)
    Layout1: TLayout;
    Layout2: TLayout;
    rectHeader: TRectangle;
    lblBack: TLabel;
    lblTitle: TLabel;
    Layout3: TLayout;
    lblNaslov: TLabel;
    lblLjubimacLabel: TLabel;
    cmbLjubimac: TComboBox;
    lblAktivnostLabel: TLabel;
    cmbAktivnost: TComboBox;
    lblResursLabel: TLabel;
    cmbResurs: TComboBox;
    lblKolicinaLabel: TLabel;
    edtKolicina: TEdit;
    lblKomentarLabel: TLabel;
    edtKomentar: TEdit;
    rectPotvrdi: TRectangle;
    lblPotvrdi: TLabel;
    rectStatus: TRectangle;
    lblStatus: TLabel;
    Layout4: TLayout;
    rectNav: TRectangle;
    procedure lblBackClick(Sender: TObject);
    procedure rectPotvrdiClick(Sender: TObject);
    procedure cmbAktivnostChange(Sender: TObject);
    procedure Loaded; override;
  private
    procedure UcitajLjubimce;
    procedure UcitajAktivnosti;
    procedure UcitajResurse;
    procedure SacuvajEvidenciju;
    procedure ProveriAlarm;
  public
  end;

implementation
{$R *.fmx}

procedure TfraEvidencija.Loaded;
begin
  inherited;
  rectStatus.Visible := False;
  UcitajLjubimce;
  UcitajAktivnosti;
  UcitajResurse;
end;

procedure TfraEvidencija.lblBackClick(Sender: TObject);
begin
  TNavFrames.Back;
end;

procedure TfraEvidencija.UcitajLjubimce;
var
  Q: TFDQuery;
begin
  cmbLjubimac.Items.Clear;
  Q := TFDQuery.Create(nil);
  try
    Q.Connection := DB;
    Q.SQL.Text := 'SELECT Sifra_ljubimca, Ime, Rasa FROM LJUBIMAC ORDER BY Ime';
    Q.Open;
    while not Q.Eof do
    begin
      cmbLjubimac.Items.Add(
        Q.FieldByName('Ime').AsString + ' (' + Q.FieldByName('Rasa').AsString + ')'
      );
      Q.Next;
    end;
  finally
    Q.Free;
  end;
end;

procedure TfraEvidencija.UcitajAktivnosti;
begin
  cmbAktivnost.Items.Clear;
  cmbAktivnost.Items.Add('Hrana');
  cmbAktivnost.Items.Add('Kupanje');
  cmbAktivnost.Items.Add('Sisanje');
  cmbAktivnost.Items.Add('Setnja');
  cmbAktivnost.Items.Add('Vakcinacija');
  cmbAktivnost.Items.Add('Veterinarski pregled');
  cmbAktivnost.Items.Add('Antiparazitska zastita');
  cmbAktivnost.Items.Add('Ostalo');
end;

procedure TfraEvidencija.UcitajResurse;
var
  Q: TFDQuery;
begin
  cmbResurs.Items.Clear;
  cmbResurs.Items.Add('-- Bez utroska resursa --');
  Q := TFDQuery.Create(nil);
  try
    Q.Connection := DB;
    Q.SQL.Text :=
      'SELECT SifraResursa, Naziv, JedinicaMere, TrenutnaKolicina ' +
      'FROM RESURS ORDER BY Naziv';
    Q.Open;
    while not Q.Eof do
    begin
      cmbResurs.Items.Add(
        Q.FieldByName('Naziv').AsString + ' (' +
        Q.FieldByName('JedinicaMere').AsString + ') — na stanju: ' +
        FormatFloat('0.#', Q.FieldByName('TrenutnaKolicina').AsFloat)
      );
      Q.Next;
    end;
  finally
    Q.Free;
  end;
  cmbResurs.ItemIndex := 0;
end;

procedure TfraEvidencija.cmbAktivnostChange(Sender: TObject);
var
  Akt: string;
begin
  if cmbAktivnost.ItemIndex < 0 then Exit;
  Akt := cmbAktivnost.Items[cmbAktivnost.ItemIndex];

  // Automatski predlozi resurs prema aktivnosti
  if Akt = 'Hrana' then
  begin
    // Trazi prvu hranu u listi
    var i: Integer;
    for i := 1 to cmbResurs.Items.Count - 1 do
      if Pos('hrana', LowerCase(cmbResurs.Items[i])) > 0 then
      begin
        cmbResurs.ItemIndex := i;
        Break;
      end;
  end
  else if (Akt = 'Vakcinacija') or (Akt = 'Antiparazitska zastita') then
  begin
    var i: Integer;
    for i := 1 to cmbResurs.Items.Count - 1 do
      if (Pos('lek', LowerCase(cmbResurs.Items[i])) > 0) or
         (Pos('tableta', LowerCase(cmbResurs.Items[i])) > 0) then
      begin
        cmbResurs.ItemIndex := i;
        Break;
      end;
  end
  else if (Akt = 'Kupanje') or (Akt = 'Sisanje') then
  begin
    var i: Integer;
    for i := 1 to cmbResurs.Items.Count - 1 do
      if (Pos('sampon', LowerCase(cmbResurs.Items[i])) > 0) or
         (Pos('kozm', LowerCase(cmbResurs.Items[i])) > 0) then
      begin
        cmbResurs.ItemIndex := i;
        Break;
      end;
  end
  else
    cmbResurs.ItemIndex := 0;
end;

procedure TfraEvidencija.SacuvajEvidenciju;
var
  Q: TFDQuery;
  Kolicina: Double;
  SifraLjubimca, SifraResursa: Integer;
  KoristiResurs: Boolean;
begin
  // Validacija
  if cmbLjubimac.ItemIndex < 0 then
  begin
    ShowMessage('Izaberite ljubimca!');
    Exit;
  end;
  if cmbAktivnost.ItemIndex < 0 then
  begin
    ShowMessage('Izaberite vrstu aktivnosti!');
    Exit;
  end;

  KoristiResurs := cmbResurs.ItemIndex > 0;

  if KoristiResurs then
  begin
    if not TryStrToFloat(edtKolicina.Text, Kolicina) or (Kolicina <= 0) then
    begin
      ShowMessage('Unesite ispravnu kolicinu resursa!');
      Exit;
    end;
  end;

  Q := TFDQuery.Create(nil);
  try
    Q.Connection := DB;

    // Uzmi SifraLjubimca
    Q.SQL.Text := 'SELECT Sifra_ljubimca FROM LJUBIMAC ORDER BY Ime LIMIT 1 OFFSET :idx';
    Q.ParamByName('idx').AsInteger := cmbLjubimac.ItemIndex;
    Q.Open;
    SifraLjubimca := Q.Fields[0].AsInteger;
    Q.Close;

    // Uzmi SifraResursa ako je izabran
    SifraResursa := 0;
    if KoristiResurs then
    begin
      Q.SQL.Text := 'SELECT SifraResursa FROM RESURS ORDER BY Naziv LIMIT 1 OFFSET :idx';
      Q.ParamByName('idx').AsInteger := cmbResurs.ItemIndex - 1;
      Q.Open;
      SifraResursa := Q.Fields[0].AsInteger;
      Q.Close;

      // Provjeri da li ima dovoljno zaliha
      Q.SQL.Text := 'SELECT TrenutnaKolicina, Naziv FROM RESURS WHERE SifraResursa = :id';
      Q.ParamByName('id').AsInteger := SifraResursa;
      Q.Open;
      if Q.Fields[0].AsFloat < Kolicina then
      begin
        ShowMessage('Nema dovoljno zaliha!' + #13#10 +
          Q.FieldByName('Naziv').AsString + ': dostupno ' +
          FormatFloat('0.#', Q.Fields[0].AsFloat) + ' jedinica.');
        Q.Close;
        Exit;
      end;
      Q.Close;
    end;

    // Upisi u DNEVNA_AKTIVNOST
    if KoristiResurs then
    begin
      Q.SQL.Text :=
        'INSERT INTO DNEVNA_AKTIVNOST ' +
        '(Vrsta_aktivnosti, Vreme_Aktivnosti, Komentar, Sifra_zaposlenog, ' +
        ' Sifra_ljubimca, SifraResursa, KolicinaUtrosena) ' +
        'VALUES (:akt, datetime(''now''), :kom, 1, :lj, :res, :kol)';
      Q.ParamByName('akt').AsString  := cmbAktivnost.Items[cmbAktivnost.ItemIndex];
      Q.ParamByName('kom').AsString  := edtKomentar.Text;
      Q.ParamByName('lj').AsInteger  := SifraLjubimca;
      Q.ParamByName('res').AsInteger := SifraResursa;
      Q.ParamByName('kol').AsFloat   := Kolicina;
      Q.ExecSQL;

      // AUTOMATSKO UMANJIVANJE ZALIHA
      Q.SQL.Text :=
        'UPDATE RESURS SET TrenutnaKolicina = TrenutnaKolicina - :kol ' +
        'WHERE SifraResursa = :id';
      Q.ParamByName('kol').AsFloat   := Kolicina;
      Q.ParamByName('id').AsInteger  := SifraResursa;
      Q.ExecSQL;
    end
    else
    begin
      Q.SQL.Text :=
        'INSERT INTO DNEVNA_AKTIVNOST ' +
        '(Vrsta_aktivnosti, Vreme_Aktivnosti, Komentar, Sifra_zaposlenog, Sifra_ljubimca) ' +
        'VALUES (:akt, datetime(''now''), :kom, 1, :lj)';
      Q.ParamByName('akt').AsString  := cmbAktivnost.Items[cmbAktivnost.ItemIndex];
      Q.ParamByName('kom').AsString  := edtKomentar.Text;
      Q.ParamByName('lj').AsInteger  := SifraLjubimca;
      Q.ExecSQL;
    end;

    // Prikazi uspjeh
    rectStatus.Fill.Color := $FF4CAF50;
    if KoristiResurs then
      lblStatus.Text := 'Aktivnost sacuvana! Zalihe umanjene za ' +
                        FormatFloat('0.#', Kolicina) + ' jed.'
    else
      lblStatus.Text := 'Aktivnost sacuvana!';
    rectStatus.Visible := True;

    // Ocisti polja
    cmbLjubimac.ItemIndex := -1;
    cmbAktivnost.ItemIndex := -1;
    cmbResurs.ItemIndex := 0;
    edtKolicina.Text := '';
    edtKomentar.Text := '';

    // Osvjezi resurse sa novim stanjima
    UcitajResurse;

    // Provjeri alarm
    if KoristiResurs then
      ProveriAlarm;

  except
    on E: Exception do
    begin
      rectStatus.Fill.Color := $FFE53935;
      lblStatus.Text := 'Greska: ' + E.Message;
      rectStatus.Visible := True;
    end;
  end;

  Q.Free;
end;

procedure TfraEvidencija.ProveriAlarm;
var
  Q: TFDQuery;
  Poruka: string;
begin
  Q := TFDQuery.Create(nil);
  try
    Q.Connection := DB;
    Q.SQL.Text :=
      'SELECT Naziv, TrenutnaKolicina, MinimaKolicina, JedinicaMere ' +
      'FROM RESURS WHERE TrenutnaKolicina < MinimaKolicina';
    Q.Open;
    Poruka := '';
    while not Q.Eof do
    begin
      Poruka := Poruka + '⚠ ' + Q.FieldByName('Naziv').AsString + ': ' +
        FormatFloat('0.#', Q.FieldByName('TrenutnaKolicina').AsFloat) + ' ' +
        Q.FieldByName('JedinicaMere').AsString +
        ' (min: ' + FormatFloat('0.#', Q.FieldByName('MinimaKolicina').AsFloat) + ')' + #13#10;
      Q.Next;
    end;
    if Poruka <> '' then
      ShowMessage('ALARM - Niske zalihe!' + #13#10 + Poruka + #13#10 +
                  'Potrebna nova nabavka!');
  finally
    Q.Free;
  end;
end;

procedure TfraEvidencija.rectPotvrdiClick(Sender: TObject);
begin
  SacuvajEvidenciju;
end;

end.
